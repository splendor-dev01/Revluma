# Environment & Secrets (NEVER PUSH)
.env
.env.*
*.pem
*.key
secrets/

# Dependencies (NEVER PUSH)
node_modules/
Backend/node_modules/
Frontend/node_modules/
Frontend/node/

# Build outputs (NEVER PUSH)
Frontend/dist/
Backend/dist/
Frontend/build/
Backend/build/
Frontend/Dashboard/dist/
Frontend/Dashboard/node_modules/

# IDE & OS files (NEVER PUSH)
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# Large files (NEVER PUSH)
*.MOV
*.mov
*.webm
*.zip
*.tar.gz
# Video files in Frontend (served from Backend)
Frontend/assets/videos/*.mp4

# Database backups (NEVER PUSH)
*.backup
*.dump
*.sql (in backup folders)

# Prisma (DO PUSH - migrations only)
prisma/migrations/
!prisma/migrations/.gitkeep

# Temporary files
*.log
*.tmp
.cache/