# ==============================================================================
#                      REVLUMA AFFILIATE PARTNER PLATFORM
#                 MASTER PRODUCTION ENVIRONMENT VARIABLE SCHEMATIC (.env)
# ==============================================================================
#
# IMPORTANT SECURITY INFORMATION:
# 1. NEVER commit your actual, populated '.env' file containing secrets to version control.
# 2. Client-safe variables must begin with 'VITE_' to be bundled into the frontend bundle.
# 3. Server-only secrets MUST NOT be prefixed with 'VITE_' to prevent client-side exposure.
#
# ==============================================================================


# ------------------------------------------------------------------------------
# 1. GENERAL CORE PLATFORM SETTINGS
# ------------------------------------------------------------------------------

# NODE_ENV: Set to 'production' in your production hosting dashboards (Vercel, Cloud Run, Render)
NODE_ENV="development"

# APP_URL: The master public URL where this app is hosted.
# Used for dynamic callbacks, self-referential links, and webhook target parameters.
# In AI Studio, this is automatically injected at runtime.
# Example: "https://your-domain.com"
APP_URL="MY_APP_URL"

# NEXT_PUBLIC_BASE_URL: Canonical frontend base URL used across backend email templates
# and referral link generation. This will be exposed to the frontend bundle so it
# must be a public URL (no secrets).
# Example: "https://revluma.example.com"
NEXT_PUBLIC_BASE_URL="https://revluma.example.com"


# ------------------------------------------------------------------------------
# 2. GOOGLE GEMINI AI CONFIGURATION (SERVER-SIDE ONLY)
# ------------------------------------------------------------------------------

# GEMINI_API_KEY: Private API token for Google Gemini model.
# Leveraged on the server endpoint (/api/gemini/generate) for the dynamic promo copilot copywriter.
# Obtain key at: https://aistudio.google.com/
GEMINI_API_KEY=""


# ------------------------------------------------------------------------------
# 3. SUPABASE RELATIONAL DATABASE CONFIGURATION
# ------------------------------------------------------------------------------

# VITE_SUPABASE_URL: Public URL representation of your Supabase database instance.
# Safe for frontend bundling.
# Obtain from: Supabase Console -> Project Settings -> API
VITE_SUPABASE_URL="https://your-supabase-project.supabase.co"

# VITE_SUPABASE_ANON_KEY: Safe, client-side public anon API token.
# Leveraged to perform client operations bound and restricted under Row Level Security (RLS) policies.
# Obtain from: Supabase Console -> Project Settings -> API
VITE_SUPABASE_ANON_KEY="your-supabase-public-anon-key"

# SUPABASE_SERVICE_ROLE_KEY: High-privilege, server-side secret key.
# WARNING: NEVER expose this to the browser! This key bypasses Row Level Security (RLS).
# Used for backend database seeding, automated triggers, and server-to-server operations.
# Obtain from: Supabase Console -> Project Settings -> API -> service_role (secret)
SUPABASE_SERVICE_ROLE_KEY=""


# ------------------------------------------------------------------------------
# 4. SUBSCRIPTION GATEWAY INTEGRATIONS (LEMON SQUEEZY)
# ------------------------------------------------------------------------------

# LEMON_SQUEEZY_API_KEY: Private authentication token for Lemon Squeezy billing audits.
# Used on the backend to dynamically list, fetch, and analyze premium product plans & customer records.
# Obtain from: Lemon Squeezy Dashboard -> Settings -> API Keys (Create API Key)
LEMON_SQUEEZY_API_KEY=""

# LEMON_SQUEEZY_WEBHOOK_SECRET: HMAC SHA256 cryptographic signature secret.
# Used to verify incoming HTTP POST events dispatched from Lemon Squeezy hooks to our backend (/api/webhooks/lemon-squeezy).
# Provide a secure random string of your choosing here, then copy-paste the exact value into Lemon Squeezy.
LEMON_SQUEEZY_WEBHOOK_SECRET="rev_luma_secret_bypass_dev_mode"


# ------------------------------------------------------------------------------
# 5. SMTP/EMAIL NOTIFICATION CONFIGURATION (RESEND PROVIDER)
# ------------------------------------------------------------------------------

# RESEND_API_KEY: Secret token for Resend SMTP service.
# Used on the server-side to send real transactional receipts, waitlist approval updates,
# and high-priority administrative payout requests notifications.
# Obtain from: https://resend.com/ -> API Keys
RESEND_API_KEY=""


# ------------------------------------------------------------------------------
# 6. AUTH RESILIENCY & TOKEN SECURING
# ------------------------------------------------------------------------------

# JWT_SECRET: Secure hexadecimal encryption signature key.
# Used on the server to cryptographically sign, inspect, and seal authentication/session state JWT cookies.
# Set a custom, high-entropy 32+ character random string in production.
JWT_SECRET=""

# NEXTAUTH_SECRET: Encryption signature key.
# Only required if migrating the authentication system over to NextAuth/Auth.js.
NEXTAUTH_SECRET=""
