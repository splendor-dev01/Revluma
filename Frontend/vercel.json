{
  "headers": [
    {
      "source": "/assets/videos/(.*)\\.mp4",
      "headers": [
        {
          "key": "Content-Type",
          "value": "video/mp4"
        },
        {
          "key": "Accept-Ranges",
          "value": "bytes"
        },
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/assets/videos/(.*)\\.MOV",
      "headers": [
        {
          "key": "Content-Type",
          "value": "video/quicktime"
        },
        {
          "key": "Accept-Ranges",
          "value": "bytes"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/dashboard/apiConfig.js",
      "destination": "/Dashboard/apiConfig.js"
    },
    {
      "source": "/dashboard/src/:path*",
      "destination": "/Dashboard/src/:path*"
    },
    {
      "source": "/dashboard/assets/:path*",
      "destination": "/assets/:path*"
    },
    {
      "source": "/dashboard/:path*",
      "destination": "/Dashboard/index.html"
    },
    {
      "source": "/dashboard",
      "destination": "/Dashboard/index.html"
    }
  ]
}